{
  "name": "smart-msg",
  "version": "1.2.1",
  "description": "AI git commit message generator (OpenAI / Claude)",
  "type": "module",
  "bin": {
    "sm": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc",
    "postversion": "git push --follow-tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "claude",
    "gemini",
    "groq",
    "ollama",
    "cli",
    "conventional-commits"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/black-astro/smart-msg.git"
  },
  "bugs": {
    "url": "https://github.com/black-astro/smart-msg/issues"
  },
  "homepage": "https://github.com/black-astro/smart-msg#readme",
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "open": "^11.0.0",
    "openai": "^6.34.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
